{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "rayclock",
  "title": "Rayclock",
  "description": "A Clock for Raycast",
  "icon": "extension-icon.png",
  "license": "MIT",
  "commands": [
    {
      "name": "stopwatch",
      "title": "Stopwatch",
      "description": "Full stopwatch with laps and live time display",
      "mode": "view"
    },
    {
      "name": "start-timer",
      "title": "Start Timer",
      "description": "Set a countdown timer with custom duration",
      "mode": "view"
    },
    {
      "name": "manage-timers",
      "title": "Manage Timers",
      "description": "View and manage active and completed timers",
      "mode": "view"
    },
    {
      "name": "world-clock",
      "title": "World Clock",
      "description": "View current time across multiple time zones",
      "mode": "view"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.103.0",
    "@raycast/utils": "^2.2.1"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.0.4",
    "@types/node": "22.13.10",
    "@types/react": "19.0.10",
    "eslint": "^9.22.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2"
  },
  "scripts": {
    "dev": "ray develop",
    "lint": "ray lint",
    "fix-lint": "ray lint --fix",
    "build": "ray build",
    "publish": "npx @raycast/api@latest publish",
    "prepublishOnly": "echo \"\\n\\nIt seems like you are trying to publish the Raycast extension to npm.\\n\\nIf you did intend to publish it to npm, remove the \\`prepublishOnly\\` script and rerun \\`npm publish\\` again.\\nIf you wanted to publish it to the Raycast Store instead, use \\`npm run publish\\` instead.\\n\\n\" && exit 1"
  },
  "author": "jnk",
  "platforms": [
    "Windows",
    "macOS"
  ],
  "categories": [
    "Productivity",
    "System"
  ],
  "preferences": [
    {
      "name": "timerSound",
      "title": "Timer Sound",
      "description": "Sound to play when a timer finishes",
      "type": "dropdown",
      "required": false,
      "default": "Alarm01.wav",
      "data": [
        {
          "title": "Alarm 1",
          "value": "Alarm01.wav"
        },
        {
          "title": "Alarm 2",
          "value": "Alarm02.wav"
        },
        {
          "title": "Alarm 3",
          "value": "Alarm03.wav"
        },
        {
          "title": "Alarm 5",
          "value": "Alarm05.wav"
        },
        {
          "title": "Alarm 10",
          "value": "Alarm10.wav"
        },
        {
          "title": "Ring 1",
          "value": "Ring01.wav"
        },
        {
          "title": "Ring 5",
          "value": "Ring05.wav"
        },
        {
          "title": "Ring 10",
          "value": "Ring10.wav"
        },
        {
          "title": "Chimes",
          "value": "chimes.wav"
        },
        {
          "title": "Chord",
          "value": "chord.wav"
        },
        {
          "title": "Ding",
          "value": "ding.wav"
        },
        {
          "title": "Notify",
          "value": "notify.wav"
        },
        {
          "title": "Tada",
          "value": "tada.wav"
        },
        {
          "title": "None",
          "value": "none"
        }
      ]
    }
  ]
}
